# 비데맵 환경변수 예시
# 실제 값을 채운 뒤 각 프로젝트 폴더에 `.env`로 복사해서 사용하세요.
# ⚠️ 실제 .env 파일은 절대 커밋하지 않습니다(.gitignore 처리됨). 이 예시 파일만 저장소에 포함합니다.

# ───────── 프론트엔드 (app/, bidet-map/) → app/.env, bidet-map/.env ─────────
VITE_SUPABASE_URL=            # Supabase 프로젝트 URL (예: https://xxxx.supabase.co)
VITE_SUPABASE_ANON_KEY=      # Supabase anon(publishable) 키 — 클라이언트용, RLS로 보호
VITE_KAKAO_JS_KEY=           # 카카오 개발자센터 JavaScript 키 (플랫폼 도메인 제한 권장)

# ───────── 관리자 웹 (admin/) → admin/.env ─────────
# VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY 만 필요 (카카오 키 불필요)

# ───────── 서버 전용 비밀값 (Supabase Function Secrets) ─────────
# 아래 값들은 .env / VITE_ 에 절대 넣지 않습니다. 프론트 번들·저장소 포함 금지.
# `supabase secrets set ...` 로만 설정하며, SUPABASE_URL/ANON/SERVICE_ROLE는 런타임에 자동 주입됩니다.
#   SUPABASE_SERVICE_ROLE_KEY   # DB 전권 키 — Edge Function 전용
#   TOSS_CLIENT_ID
#   TOSS_CLIENT_SECRET
#   TOSS_API_BASE               # 예: https://apps-in-toss-api.toss.im
#   MODERATION_API_URL          # (선택) 이미지 자동 검열 연동
#   MODERATION_API_KEY          # (선택)
